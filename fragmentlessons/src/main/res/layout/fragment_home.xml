<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    >

    <!-- Заголовок -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Медиа Плеер"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="40dp"/>

    <!-- Кнопки навигации -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Кнопка Фото -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            >

            <Button
                android:id="@+id/btnToPhotos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📷 Фото Галерея"
                android:textSize="18sp"
                android:padding="16dp"
                android:background="@color/purple_500"
                android:textColor="@color/white"/>

        </androidx.cardview.widget.CardView>

        <!-- Кнопка Аудио -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
           >

            <Button
                android:id="@+id/btnToAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎵 Аудио Плеер"
                android:textSize="18sp"
                android:padding="16dp"
                android:textColor="@color/white"/>

        </androidx.cardview.widget.CardView>

        <!-- Кнопка Видео -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >

            <Button
                android:id="@+id/btnToVideo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎬 Видео Плеер"
                android:textSize="18sp"
                android:padding="16dp"
                android:background="@color/green_500"
                android:textColor="@color/white"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Информация о разрешениях -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Для доступа к медиатеке устройства\nнеобходимы разрешения"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:padding="12dp"
        android:background="@color/purple_700"
        android:drawablePadding="8dp"/>

</LinearLayout>