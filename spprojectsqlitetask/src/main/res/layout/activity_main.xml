<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="?android:colorBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/title_name"
                        android:textSize="28sp"
                        android:padding="5dp"
                        android:textStyle="bold"
                        android:textColor="?android:textColorPrimary" />

                    <TextView
                        android:id="@+id/title_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="5dp"
                        android:textStyle="bold"
                        android:text="@string/text_time"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>

            <!-- Статистика (3 карточки) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="?android:colorBackground">

                <!-- Активные задачи -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="?android:colorBackground"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"

                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/baseline_checklist_24"
                            android:tint="@color/blue"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Активные"
                            android:textSize="14sp"
                            android:textColor="?android:textColorSecondary"/>

                        <TextView
                            android:id="@+id/active"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?android:textColorPrimary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Выполненные задачи -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="?android:colorBackground"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/baseline_task_alt_24"
                            android:tint="@color/green"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Выполнено"
                            android:textSize="14sp"
                            android:textColor="?android:textColorSecondary"/>

                        <TextView
                            android:id="@+id/complete"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?android:textColorPrimary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Прогресс -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="?android:colorBackground"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/baseline_incomplete_circle_24"
                            android:tint="@color/blue"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Прогресс"
                            android:textSize="14sp"
                            android:textColor="?android:textColorSecondary"/>

                        <TextView
                            android:id="@+id/porgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0%"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?android:textColorPrimary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Фильтры (Все, Активные, Выполненные) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                android:paddingHorizontal="8dp"
                android:paddingVertical="1dp"
                android:background="?android:colorBackground">

                <androidx.cardview.widget.CardView
                    android:id="@+id/all_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="25dp"
                    app:cardBackgroundColor="?android:colorBackground"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:layout_margin="4dp"
                    android:focusable="true"

                    android:foreground="?android:attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/tv_all_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="10dp"
                        android:text="Все"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/active_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="25dp"
                    app:cardBackgroundColor="?android:colorBackground"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="4dp"
                    android:foreground="?android:attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/tv_active_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Активные"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?android:textColorPrimary"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="18dp"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/complete_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="25dp"
                    app:cardBackgroundColor="?android:colorBackground"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="4dp"
                    android:foreground="?android:attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/tv_completed_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Выполнено"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?android:textColorPrimary"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="18dp"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_sort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="25dp"
                    app:cardBackgroundColor="?android:colorBackground"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="4dp"
                    android:foreground="?android:attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/iv_sort_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_sort"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="12dp"/>
                </androidx.cardview.widget.CardView>

            </LinearLayout>




            <!-- RecyclerView для списка задач -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/reclist"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="?android:colorBackground"/>

            <!-- Сообщение о пустом списке -->
            <TextView
                android:id="@+id/tv_empty_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="18sp"
                android:textColor="?android:textColorSecondary"
                android:textStyle="bold"
                android:visibility="gone"
                android:text="Нет задач" />

            <!-- Floating Action Button для добавления задачи -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAdd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp"
                android:src="@drawable/baseline_add_24"
                android:tint="@color/white"
                app:backgroundTint="@color/blue"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:elevation="4dp"/>

        </LinearLayout>
    </FrameLayout>

</LinearLayout>