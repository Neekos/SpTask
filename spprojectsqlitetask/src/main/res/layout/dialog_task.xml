<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <!-- Заголовок диалога -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Новая задача"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        android:layout_marginBottom="24dp"
        android:gravity="center"/>

    <!-- Поле для ввода названия -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/blue"
        app:hintTextColor="@color/blue"
        app:placeholderTextColor="?android:textColorSecondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название задачи"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:paddingVertical="12dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Поле для ввода описания -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/blue"
        app:hintTextColor="@color/blue"
        app:placeholderTextColor="?android:textColorSecondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Описание задачи"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary"
            android:paddingVertical="12dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Заголовок выбора сложности -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сложность:"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:textColorPrimary"
        android:layout_marginBottom="12dp"/>

    <!-- Карточки выбора сложности -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- EASY -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_easy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/light_green"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/tv_easy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EASY"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="12dp"/>
        </androidx.cardview.widget.CardView>

        <!-- MEDIUM -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_medium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/light_orange"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/tv_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MEDIUM"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="12dp"/>
        </androidx.cardview.widget.CardView>

        <!-- HARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_hard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/light_red"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/tv_hard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HARD"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="12dp"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Кнопки действий -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <!-- Кнопка Отмена -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/gray"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardElevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Отмена"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="14dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Кнопка Сохранить -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/blue"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardElevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сохранить"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="14dp"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</LinearLayout>